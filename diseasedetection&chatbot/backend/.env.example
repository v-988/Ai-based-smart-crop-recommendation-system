# ==============================================
# Plant Disease Detection API - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values

# ==============================================
# Application Settings
# ==============================================
APP_NAME="Plant Disease Detection & Farmer Chatbot API"
APP_VERSION="1.0.0"
DEBUG=false

# ==============================================
# Server Configuration
# ==============================================
HOST=0.0.0.0
PORT=8000

# ==============================================
# CORS Settings (comma-separated origins)
# ==============================================
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ==============================================
# HuggingFace API Configuration
# Get your API key from: https://huggingface.co/settings/tokens
# ==============================================
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL_URL=https://router.huggingface.co/hf-inference/models/linkanjarad/mobilenet_v2_1.0_224-plant-disease-identification

# ==============================================
# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/keys
# ==============================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ==============================================
# Groq API Configuration (fallback provider)
# Get your API key from: https://console.groq.com/keys
# ==============================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,llama-3.1-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ==============================================
# Chat Configuration
# ==============================================
MAX_CHAT_HISTORY=10
MAX_TOKENS=500
TEMPERATURE=0.3
MAX_CONTINUATION_LOOPS=4

# ==============================================
# File Upload Configuration
# ==============================================
MAX_IMAGE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# ==============================================
# Voice Configuration
# ==============================================
TEMP_AUDIO_DIR=temp_audio

# ==============================================
# Logging
# ==============================================
LOG_LEVEL=INFO
