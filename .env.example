# Example Environment Variables for Deployment
# Copy these to your Render Dashboard > Environment Variables
# Do NOT commit your actual .env file with real keys to GitHub!

OPENWEATHER_API_KEY=your_key_here
AMBEE_API_KEY=your_key_here
AGROMONITORING_APPID=your_key_here
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=arcee-ai/trinity-mini:free
OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-super-120b-a12b:free,stepfun/step-3.5-flash:free,arcee-ai/trinity-large-preview:free,liquid/lfm-2.5-1.2b-thinking:free,liquid/lfm-2.5-1.2b-instruct:free
HUGGINGFACE_API_KEY=your_key_here
MAX_CONTINUATION_LOOPS=1
